"File: PCBGameCardStm32.csolution.yml" = """
# yaml-language-server: $schema=https://raw.githubusercontent.com/Open-CMSIS-Pack/devtools/schemas/projmgr/2.11.0/tools/projmgr/schemas/csolution.schema.json
solution:
  output-dirs:
    tmpdir: project/tmp
    outdir: $SolutionDir()$/build/$Project$.$BuildType$
  generators:
    base-dir: $ProjectDir()$/generated
  build-types:
    - type: debug_GCC
      compiler: GCC
    - type: release_GCC
      compiler: GCC
    - type: debug_IAR
      compiler: IAR
    - type: release_IAR
      compiler: IAR
    - type: debug_AC6
      compiler: AC6
    - type: release_AC6
      compiler: AC6
  target-types:
    - type: STM32C562KET6
      device: STM32C562KET6
  projects:
    - project: project/PCBGameCardStm32.cproject.yml
  packs:
    - pack: STMicroelectronics::CMSIS@6.3.0
    - pack: STMicroelectronics::stm32c5xx_dfp@2.1.0
    - pack: STMicroelectronics::stm32c5xx_hal_drivers@2.1.0
    - pack: STMicroelectronics::stm32cubemx2_templates_no_os_stm32c5@2.1.0
    - pack: STMicroelectronics::syscalls@2.0.0
"""
